---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import resume from "../content/resume.json";

const { basics, summary, skills, legacySkills, languages, experience, projects, education, ongoingLearning, stats, certifications } = resume;

const fmtMonth = (ym) => {
  if (!ym) return "Present";
  const [y, m] = ym.split("-").map(Number);
  const d = new Date(y, (m || 1) - 1, 1);
  return d.toLocaleString("en-US", { month: "short", year: "numeric" });
};

const mailTo = `mailto:${basics.email}`;
const telTo = `tel:${basics.phone.replace(/\s/g, "")}`;
const base = import.meta.env.BASE_URL;
const resumePdf = `${base.replace(/\/$/, "")}/resume.pdf`;
---

<BaseLayout title={`${basics.name} — ${basics.label}`}>
  <a id="top" class="sr-only">Top</a>
  <div class="relative">
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-20 grain"></div>
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10 overflow-hidden ambient-layer">
      <div class="ambient-orb ambient-orb-cyan absolute left-1/2 top-[-120px] h-[500px] w-[900px] -translate-x-1/2 rounded-full bg-cyan-400/10 blur-3xl"></div>
      <div class="ambient-orb ambient-orb-fuchsia absolute left-[10%] top-[380px] h-[260px] w-[520px] rounded-full bg-fuchsia-400/10 blur-3xl"></div>
      <div class="ambient-orb ambient-orb-cyan absolute right-[5%] bottom-[-100px] h-[400px] w-[700px] rounded-full bg-cyan-400/10 blur-3xl"></div>
    </div>

    <header class="pt-10 sm:pt-14">
      <div class="container-page">
        <div class="flex flex-col gap-6">
          <div class="flex flex-col gap-3">
            <p class="text-xs font-medium tracking-[0.2em] uppercase muted">Resume</p>
            <h1 class="hero-title text-4xl sm:text-6xl font-semibold tracking-tight bg-gradient-to-b from-white to-white/70 bg-clip-text text-transparent">
              {basics.name}
            </h1>
            <p class="text-lg sm:text-xl muted">{basics.label} · {basics.location}</p>
            <div class="mt-1 flex flex-wrap items-center gap-2">
              <a class="focus-ring inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-sm font-medium hover:bg-white/10 magnetic-btn" href={basics.socials.github} target="_blank" rel="noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.76.4-1.27.74-1.56-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.2-3.1-.12-.29-.52-1.46.11-3.05 0 0 .98-.31 3.2 1.18a11 11 0 0 1 5.82 0c2.22-1.5 3.2-1.18 3.2-1.18.63 1.59.23 2.76.11 3.05.75.81 1.2 1.84 1.2 3.1 0 4.43-2.7 5.4-5.28 5.69.42.36.79 1.07.79 2.16v3.2c0 .31.2.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"/></svg>
                GitHub
              </a>
              <a class="focus-ring inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-sm font-medium hover:bg-white/10 magnetic-btn" href={basics.socials.linkedin} target="_blank" rel="noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0Z"/></svg>
                LinkedIn
              </a>
            </div>
          </div>

          <div class="card card-elevated shine p-5 sm:p-7">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <div class="max-w-2xl">
                <p class="text-base sm:text-lg leading-relaxed">
                  <span class="font-medium">Focused on real-time systems</span> and reliable backend services, with hands-on embedded/cloud integrations.
                </p>
                <p class="mt-2 muted leading-relaxed">{summary.join(" ")}</p>
              </div>

              <div class="flex flex-wrap gap-3">
                <button class="btn btn-primary magnetic-btn copy-btn" data-copy={basics.email}>
                  Email
                </button>
                <button class="btn btn-ghost magnetic-btn copy-btn" data-copy={basics.phone}>
                  Call
                </button>
                <a class="btn btn-ghost" href="#experience">
                  Experience
                </a>
                <a class="btn btn-ghost" href="#projects">
                  Projects
                </a>
              </div>
            </div>

            <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
              <div class="rounded-xl border border-white/10 bg-black/20 p-4">
                <p class="text-xs uppercase tracking-[0.2em] muted">Email</p>
                <p class="mt-1 font-mono text-sm">{basics.email}</p>
              </div>
              <div class="rounded-xl border border-white/10 bg-black/20 p-4">
                <p class="text-xs uppercase tracking-[0.2em] muted">Phone</p>
                <p class="mt-1 font-mono text-sm">{basics.phone}</p>
              </div>
              <div class="rounded-xl border border-white/10 bg-black/20 p-4">
                <p class="text-xs uppercase tracking-[0.2em] muted">Stack</p>
                <p class="mt-1 text-sm">
                  <span class="kbd">Frontend</span>
                  <span class="kbd ml-2">Backend</span>
                  <span class="kbd ml-2">CI/CD</span>
                </p>
              </div>
            </div>

            <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
              {stats?.map((s) => (
                <div class="rounded-xl border border-white/10 bg-black/20 p-4 text-center">
                  <p class="stat-value text-2xl sm:text-3xl font-semibold tracking-tight" data-countup={String(s.value)} data-suffix={s.suffix || ""}>0{s.suffix || ""}</p>
                  <p class="mt-1 text-xs muted">{s.label}</p>
                </div>
              ))}
            </div>
          </div>

          <nav class="sticky top-4 z-10 -mx-2 flex flex-wrap items-center gap-2 rounded-2xl border border-white/10 bg-black/40 p-2 backdrop-blur-md">
            <a class="nav-link focus-ring rounded-xl px-3 py-2 text-sm muted hover:bg-white/5" href="#experience">Experience</a>
            <a class="nav-link focus-ring rounded-xl px-3 py-2 text-sm muted hover:bg-white/5" href="#projects">Projects</a>
            <a class="nav-link focus-ring rounded-xl px-3 py-2 text-sm muted hover:bg-white/5" href="#skills">Skills</a>
            <a class="nav-link focus-ring rounded-xl px-3 py-2 text-sm muted hover:bg-white/5" href="#education">Education</a>
            <a class="nav-link focus-ring rounded-xl px-3 py-2 text-sm muted hover:bg-white/5" href="#learning">Learning</a>
            <a class="nav-link focus-ring rounded-xl px-3 py-2 text-sm muted hover:bg-white/5" href="#certifications">Certs</a>
            <button id="cmdk-trigger" type="button" class="focus-ring ml-auto hidden sm:inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-sm muted hover:bg-white/10">
              Jump to <span class="kbd">Ctrl K</span>
            </button>
            <button id="theme-toggle" type="button" aria-label="Toggle theme" class="focus-ring inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 p-2 hover:bg-white/10">
              <svg class="theme-icon-dark" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
              <svg class="theme-icon-light hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            </button>
            <a class="focus-ring rounded-xl bg-white/10 px-3 py-2 text-sm font-medium hover:bg-white/20 transition-colors magnetic-btn" href={resumePdf} download>Download Resume</a>
          </nav>
        </div>
      </div>
    </header>

    <main class="pb-20">
      <Section id="experience" title="Experience" eyebrow="Proof of work">
        <div class="flex flex-col gap-4">
          <div class="rounded-xl border border-white/10 bg-black/20 p-4 sm:p-5">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between">
              <p class="text-sm muted">
                Tip: filter bullets by focus. <span class="kbd">Realtime</span> <span class="kbd ml-1">Embedded</span> <span class="kbd ml-1">Web</span> <span class="kbd ml-1">ML</span>
              </p>
              <div class="flex flex-wrap gap-2" id="focusToggle">
                {["All", "Realtime", "Embedded", "Web", "DevOps", "ML"].map((t) => (
                  <button
                    type="button"
                    class="focus-ring rounded-xl border border-white/10 bg-white/5 px-3 py-1.5 text-xs font-medium hover:bg-white/10"
                    data-focus={t}
                  >
                    {t}
                  </button>
                ))}
              </div>
            </div>
          </div>

          <div class="relative grid gap-4 pl-4 sm:pl-8 before:absolute before:inset-y-0 before:left-[7px] sm:before:left-[15px] before:w-px before:bg-white/10">
            {experience.map((role) => (
              <div class="relative">
                <div class="timeline-dot absolute left-[-29px] sm:left-[-37px] top-8 h-3 w-3 rounded-full border-2 border-cyan-400 bg-black shadow-[0_0_8px_rgba(34,211,238,0.6)]"></div>
                <article class="spotlight-card rounded-2xl border border-white/10 bg-black/20 p-5 sm:p-6 transition-colors hover:border-white/20 hover:bg-black/30">
                  <header class="tilt-inner flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                    <div>
                      <h3 class="text-lg font-semibold tracking-tight">{role.title}</h3>
                      <p class="mt-1 muted">
                        <span class="font-medium text-white/90">{role.company}</span>
                        <span class="mx-2 text-white/20">·</span>
                        <span>{role.location}</span>
                        <span class="mx-2 text-white/20">·</span>
                        <span>{role.type}</span>
                      </p>
                    </div>
                    <p class="text-sm muted font-mono">
                      {fmtMonth(role.start)} — {fmtMonth(role.end)}
                    </p>
                  </header>

                  <div class="mt-4 flex flex-wrap gap-2">
                    {role.tags.map((tag) => (
                      <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-1 text-[11px] font-medium muted">{tag}</span>
                    ))}
                  </div>

                  {role.metrics?.length ? (
                    <div class="mt-4 grid gap-2 sm:grid-cols-2">
                      {role.metrics.map((m) => (
                        <div class="rounded-xl border border-white/10 bg-white/5 p-3">
                          <p class="text-[11px] uppercase tracking-[0.15em] muted">{m.label}</p>
                          <p class="mt-1 text-sm font-mono">{m.value}</p>
                        </div>
                      ))}
                    </div>
                  ) : null}

                  <details class="mt-4 group">
                    <summary class="cursor-pointer list-none select-none focus-ring rounded-xl px-3 py-2 -mx-3 hover:bg-white/5 flex items-center justify-between">
                      <span class="text-sm font-medium">Highlights</span>
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-open:rotate-180 muted"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </summary>
                    <ul class="mt-3 grid gap-2 pl-5">
                      {role.highlights.map((h) => (
                        <li class="text-sm leading-relaxed" data-tags={role.tags.join(",")}>
                          <span class="muted">•</span> <span class="ml-2">{h}</span>
                        </li>
                      ))}
                    </ul>
                  </details>
                </article>
              </div>
            ))}
          </div>
        </div>
      </Section>

      <Section id="projects" title="Projects" eyebrow="Systems you built">
        <div class="grid gap-4 lg:grid-cols-2">
          {projects?.map((p) => (
            <article class={`spotlight-card rounded-2xl border border-white/10 bg-black/20 p-5 sm:p-6 transition-colors hover:border-white/20 hover:bg-black/30 ${p.featured ? "lg:col-span-2 shine" : ""}`}>
              <header class="tilt-inner flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <div class="flex items-center gap-2">
                    <h3 class="text-lg font-semibold tracking-tight">{p.title}</h3>
                    {p.featured ? (
                      <span class="badge-accent rounded-full border border-cyan-300/30 bg-cyan-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.15em] text-cyan-200">Featured</span>
                    ) : null}
                  </div>
                  <p class="mt-1 muted">
                    <span class="font-medium text-white/90">{p.subtitle}</span>
                  </p>
                  <p class="mt-2 text-sm font-mono muted">{p.timeframe}</p>
                </div>
              </header>

              <p class="mt-4 text-sm leading-relaxed muted">{p.description}</p>

              {p.architecture?.length ? (
                <div class="mt-4 rounded-2xl border border-white/10 bg-black/20 p-4">
                  <p class="text-xs font-medium tracking-[0.2em] uppercase muted">Architecture</p>
                  <div class="arch-flow mt-3">
                    {p.architecture.map((a) => (
                      <div class="arch-node rounded-xl border border-white/10 bg-white/5 p-3">
                        <p class="text-sm font-semibold">{a.node}</p>
                        <p class="mt-1 text-xs muted">{a.detail}</p>
                      </div>
                    ))}
                  </div>
                </div>
              ) : null}

              <div class="mt-4 flex flex-wrap gap-2">
                {p.tags.map((tag) => (
                  <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-1 text-[11px] font-medium muted">
                    {tag}
                  </span>
                ))}
              </div>

              <details class="mt-4 group">
                <summary class="cursor-pointer list-none select-none focus-ring rounded-xl px-3 py-2 -mx-3 hover:bg-white/5 flex items-center justify-between">
                  <span class="text-sm font-medium">What I built</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-open:rotate-180 muted"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </summary>
                <ul class="mt-3 grid gap-2 pl-5">
                  {p.highlights.map((h) => (
                    <li class="text-sm leading-relaxed">
                      <span class="muted">•</span> <span class="ml-2">{h}</span>
                    </li>
                  ))}
                </ul>
              </details>

              {p.metrics?.length ? (
                <div class="mt-4 rounded-2xl border border-white/10 bg-black/20 p-4">
                  <p class="text-xs font-medium tracking-[0.2em] uppercase muted">Impact</p>
                  <div class="mt-3 grid gap-2 sm:grid-cols-2">
                    {p.metrics.map((m) => (
                      <div class="rounded-xl border border-white/10 bg-white/5 p-3">
                        <p class="text-xs muted">{m.label}</p>
                        <p class="mt-1 text-sm font-mono">{m.value}</p>
                      </div>
                    ))}
                  </div>
                </div>
              ) : null}

              <div class="mt-4">
                <p class="text-xs font-medium tracking-[0.2em] uppercase muted">Tech stack</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {p.techStack.map((t) => (
                    <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium">{t}</span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </Section>

      <Section id="skills" title="Skills" eyebrow="Tooling">
        <div class="grid gap-5">
          <div class="marquee-container overflow-hidden rounded-2xl border border-white/10 bg-black/20 py-4 w-full relative">
            <div class="animate-marquee flex w-max gap-4 px-4">
              {[...Object.values(skills).flat(), ...Object.values(skills).flat()].map(skill => (
                <span class="skill-pill-marquee">{skill}</span>
              ))}
            </div>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {Object.entries(skills).map(([group, items]) => (
              <div class="rounded-2xl border border-white/10 bg-black/20 p-5 transition-all hover:-translate-y-1 hover:border-white/20 hover:bg-black/30">
                <p class="text-xs font-medium tracking-[0.2em] uppercase muted">{group}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {items.map((s) => (
                    <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium">{s}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>

          <div class="rounded-2xl border border-white/10 bg-black/20 p-5 transition-all hover:-translate-y-1 hover:border-white/20 hover:bg-black/30">
            <p class="text-xs font-medium tracking-[0.2em] uppercase muted">Also worked with</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {legacySkills.map((s) => (
                <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium muted">{s}</span>
              ))}
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-black/20 p-5 transition-all hover:-translate-y-1 hover:border-white/20 hover:bg-black/30">
            <p class="text-xs font-medium tracking-[0.2em] uppercase muted">Languages</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {languages.map((l) => (
                <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium">
                  {l.name} <span class="muted">· {l.level}</span>
                </span>
              ))}
            </div>
          </div>
        </div>
      </Section>

      <Section id="education" title="Education" eyebrow="Foundations">
        <div class="grid gap-4 sm:grid-cols-2">
          {education.map((e) => (
            <div class="rounded-2xl border border-white/10 bg-black/20 p-5 transition-all hover:-translate-y-1 hover:border-white/20 hover:bg-black/30">
              <h3 class="text-base font-semibold tracking-tight">{e.degree}</h3>
              <p class="mt-1 muted">{e.school} · {e.location}</p>
              <p class="mt-3 text-sm font-mono muted">{fmtMonth(e.start)} — {fmtMonth(e.end)}</p>
            </div>
          ))}
        </div>
      </Section>

      <Section id="learning" title="Ongoing learning" eyebrow="Now">
        <div class="grid gap-4">
          {ongoingLearning.map((c) => (
            <div class="rounded-2xl border border-white/10 bg-black/20 p-5 transition-all hover:-translate-y-1 hover:border-white/20 hover:bg-black/30">
              <h3 class="text-base font-semibold tracking-tight">{c.title}</h3>
              <p class="mt-1 muted">{c.status}</p>
            </div>
          ))}
        </div>
      </Section>

      <Section id="certifications" title="Certifications" eyebrow="Credentials">
        <div class="grid gap-4 sm:grid-cols-2">
          {certifications?.map((c) => (
            <div class="rounded-2xl border border-white/10 bg-black/20 p-5 transition-all hover:-translate-y-1 hover:border-white/20 hover:bg-black/30">
              <div class="flex items-start justify-between gap-3">
                <h3 class="text-base font-semibold tracking-tight">{c.title}</h3>
                {c.status ? (
                  <span class="badge-accent shrink-0 rounded-full border border-cyan-300/30 bg-cyan-400/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.15em] text-cyan-200">{c.status}</span>
                ) : null}
              </div>
              <p class="mt-1 muted">{c.issuer}</p>
              <p class="mt-3 text-sm font-mono muted">{c.date}</p>
            </div>
          ))}
        </div>
      </Section>

      <footer class="pt-2 pb-10">
        <div class="container-page">
          <div class="card p-5 sm:p-7 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-sm muted">
              Built with Astro + Tailwind. Hosted on GitHub Pages.
            </p>
            <div class="flex flex-wrap gap-2 text-sm">
              <a class="focus-ring rounded-lg px-3 py-2 hover:bg-white/5" href={mailTo}>Email</a>
              <a class="focus-ring rounded-lg px-3 py-2 hover:bg-white/5" href={telTo}>Call</a>
              <a class="focus-ring rounded-lg px-3 py-2 hover:bg-white/5" href="#top">Back to top</a>
            </div>
          </div>
        </div>
      </footer>
    </main>
  </div>

  <script is:inline>
    (function () {
      const root = document.getElementById("focusToggle");
      if (!root) return;

      const buttons = Array.from(root.querySelectorAll("button[data-focus]"));
      const allBullets = Array.from(document.querySelectorAll("[data-tags]"));

      function setActive(focus) {
        buttons.forEach((b) => {
          const on = b.getAttribute("data-focus") === focus;
          b.classList.toggle("bg-cyan-400/15", on);
          b.classList.toggle("text-cyan-200", on);
          b.classList.toggle("border-cyan-300/20", on);
          b.classList.toggle("bg-white/5", !on);
        });

        allBullets.forEach((el) => {
          const tags = (el.getAttribute("data-tags") || "").split(",").map((t) => t.trim());
          const show = focus === "All" ? true : tags.includes(focus);
          el.style.display = show ? "" : "none";
          
          if (show && focus !== "All") {
            const details = el.closest("details");
            if (details) details.open = true;
          }
        });
      }

      buttons.forEach((b) => {
        b.addEventListener("click", () => setActive(b.getAttribute("data-focus") || "All"));
      });

      setActive("All");
    })();
  </script>

  <script is:inline>
    (function () {
      const nodes = Array.from(document.querySelectorAll("[data-reveal]"));
      if (!nodes.length) return;

      const io = new IntersectionObserver(
        (entries) => {
          // Group entries that intersect at the same time for staggered delay
          let delay = 0;
          for (const e of entries) {
            if (e.isIntersecting) {
              const children = e.target.querySelectorAll(".transition-all, .rounded-2xl");
              if (children.length > 1) {
                children.forEach((child, i) => {
                  child.style.transitionDelay = `${i * 100}ms`;
                  child.classList.add("in-view");
                });
              }
              e.target.classList.add("in-view");
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12 }
      );

      nodes.forEach((n) => io.observe(n));
    })();
  </script>

  <script is:inline>
    // Spotlight glow only (no 3D tilt — avoids cursor/hit-target issues)
    (function () {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      const cards = document.querySelectorAll(".spotlight-card");
      cards.forEach((card) => {
        card.addEventListener("mousemove", (e) => {
          const rect = card.getBoundingClientRect();
          card.style.setProperty("--mouse-x", `${e.clientX - rect.left}px`);
          card.style.setProperty("--mouse-y", `${e.clientY - rect.top}px`);
        });
        card.addEventListener("mouseleave", () => {
          card.style.removeProperty("--mouse-x");
          card.style.removeProperty("--mouse-y");
        });
      });
    })();
  </script>

  <script is:inline>
    // Clipboard Copy
    (function () {
      const copyBtns = document.querySelectorAll('.copy-btn');
      copyBtns.forEach(btn => {
        btn.addEventListener('click', async () => {
          const text = btn.getAttribute('data-copy');
          if (!text) return;
          try {
            await navigator.clipboard.writeText(text);
            btn.classList.add('copied');
            setTimeout(() => btn.classList.remove('copied'), 2000);
          } catch (err) {
            console.error('Failed to copy', err);
          }
        });
      });
    })();
  </script>

  <div id="cmdk-overlay" role="dialog" aria-modal="true" aria-label="Jump to section">
    <div class="cmdk-panel">
      <input id="cmdk-input" type="text" placeholder="Jump to a section..." class="w-full border-b border-white/10 bg-transparent px-4 py-3 text-sm outline-none" autocomplete="off" />
      <ul id="cmdk-list" class="max-h-72 overflow-y-auto p-2"></ul>
    </div>
  </div>

  <script is:inline>
    // Scroll progress bar
    (function () {
      const bar = document.getElementById("scroll-progress");
      if (!bar) return;
      const onScroll = () => {
        const h = document.documentElement;
        const max = h.scrollHeight - h.clientHeight;
        const pct = max > 0 ? (h.scrollTop / max) * 100 : 0;
        bar.style.width = pct + "%";
      };
      document.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    })();

    // Count-up stats
    (function () {
      const els = Array.from(document.querySelectorAll("[data-countup]"));
      if (!els.length) return;
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const run = (el) => {
        const target = parseFloat(el.getAttribute("data-countup") || "0");
        const suffix = el.getAttribute("data-suffix") || "";
        if (reduce) { el.textContent = target + suffix; return; }
        const dur = 1200;
        const start = performance.now();
        const step = (now) => {
          const t = Math.min((now - start) / dur, 1);
          const eased = 1 - Math.pow(1 - t, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (t < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      };
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { run(e.target); io.unobserve(e.target); }
        }
      }, { threshold: 0.5 });
      els.forEach((el) => io.observe(el));
    })();

    // Scroll-spy active nav
    (function () {
      const links = Array.from(document.querySelectorAll(".nav-link"));
      if (!links.length) return;
      const map = new Map();
      links.forEach((l) => {
        const id = (l.getAttribute("href") || "").replace("#", "");
        const sec = document.getElementById(id);
        if (sec) map.set(sec, l);
      });
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            links.forEach((l) => l.classList.remove("active"));
            const link = map.get(e.target);
            if (link) link.classList.add("active");
          }
        });
      }, { rootMargin: "-40% 0px -55% 0px" });
      map.forEach((_, sec) => io.observe(sec));
    })();

    // Theme toggle
    (function () {
      const btn = document.getElementById("theme-toggle");
      if (!btn) return;
      const dark = btn.querySelector(".theme-icon-dark");
      const light = btn.querySelector(".theme-icon-light");
      const sync = () => {
        const isLight = document.documentElement.classList.contains("light");
        if (dark) dark.classList.toggle("hidden", isLight);
        if (light) light.classList.toggle("hidden", !isLight);
      };
      sync();
      btn.addEventListener("click", () => {
        const isLight = document.documentElement.classList.toggle("light");
        try { localStorage.setItem("theme", isLight ? "light" : "dark"); } catch (e) {}
        sync();
      });
    })();

    // Command palette
    (function () {
      const overlay = document.getElementById("cmdk-overlay");
      const input = document.getElementById("cmdk-input");
      const list = document.getElementById("cmdk-list");
      const trigger = document.getElementById("cmdk-trigger");
      if (!overlay || !input || !list) return;

      const items = Array.from(document.querySelectorAll(".nav-link")).map((l) => ({
        label: l.textContent.trim(),
        href: l.getAttribute("href")
      }));
      let selected = 0;

      const renderList = (filter) => {
        const f = (filter || "").toLowerCase();
        const filtered = items.filter((it) => it.label.toLowerCase().includes(f));
        list.innerHTML = "";
        filtered.forEach((it, i) => {
          const li = document.createElement("li");
          li.className = "cmdk-item cursor-pointer rounded-lg px-3 py-2 text-sm";
          li.setAttribute("aria-selected", String(i === selected));
          li.textContent = it.label;
          li.addEventListener("click", () => go(it.href));
          list.appendChild(li);
        });
        return filtered;
      };

      const open = () => { overlay.classList.add("open"); input.value = ""; selected = 0; renderList(""); setTimeout(() => input.focus(), 20); };
      const close = () => overlay.classList.remove("open");
      const go = (href) => { close(); if (href) { document.querySelector(href)?.scrollIntoView({ behavior: "smooth" }); } };

      trigger?.addEventListener("click", open);
      document.addEventListener("keydown", (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "k") { e.preventDefault(); overlay.classList.contains("open") ? close() : open(); }
        if (!overlay.classList.contains("open")) return;
        const current = renderList(input.value);
        if (e.key === "Escape") close();
        if (e.key === "ArrowDown") { e.preventDefault(); selected = Math.min(selected + 1, current.length - 1); renderList(input.value); }
        if (e.key === "ArrowUp") { e.preventDefault(); selected = Math.max(selected - 1, 0); renderList(input.value); }
        if (e.key === "Enter") { e.preventDefault(); if (current[selected]) go(current[selected].href); }
      });
      input.addEventListener("input", () => { selected = 0; renderList(input.value); });
      overlay.addEventListener("click", (e) => { if (e.target === overlay) close(); });
    })();
  </script>
</BaseLayout>

